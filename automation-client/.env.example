VITE_KAPTURE_MCP_WS_URL=ws://localhost:61822/mcp
# Optional: launcher command to auto-start MCP when port is down
# Example:
# KAPTURE_MCP_START_CMD=npx -y kapture-mcp bridge
KAPTURE_MCP_START_CMD=
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODELS=stepfun/step-3.5-flash:free,qwen/qwen3-4b:free,google/gemma-3-4b-it:free,meta-llama/llama-3.2-3b-instruct:free,openrouter/auto,openai/gpt-4o-mini
VITE_OPENROUTER_HTTP_REFERER=http://localhost:5180
VITE_OPENROUTER_TITLE=Kapture Automation Client
VITE_OPENROUTER_REASONING_EFFORT=low
VITE_OPENROUTER_REASONING_EXCLUDE=true

